{# Si seul le corps du document est demandé #}
{% if corps|default(false) %}
    {% include 'courrier/arretePaiement/_arrete_corps.html.twig' %}
{# Sinon générer le courrier entier, avec en-tête et pied de page #}
{% else %}
    {% extends 'courrier/_base_courrier.html.twig' %}

    {% block style %}
        <style>
            h3, h4 {
                font-weight: bold;
                font-size: 1rem;
                line-height: 1.2rem;
                text-align: center;
                text-transform: uppercase;
            }
        </style>
    {% endblock style %}



    {% block pages %}

        <header>

            <div id="logo-ministere">
                {% include 'courrier/logo_ministere.svg' %}
            </div>

        </header>

        {% if corps is defined and corps is not null %}
            {{ corps|raw }}
        {% else %}
            {% include 'courrier/arretePaiement/_arrete_corps.html.twig' %}
        {% endif %}

        <p>Fait à Paris, le {{ 'now'|format_datetime(locale='fr',pattern="d MMMM yyyy", timezone: 'Europe/Paris') }}</p>


        <p class="text-centre" style="width: 30%;margin:auto;">
            <b>Pour le garde des Sceaux,<br>
                ministre de la Justice<br/>
                et par délégation</b>
        </p>
    {% endblock pages %}
{% end %}