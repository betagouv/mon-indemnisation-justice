{% extends 'email/base_email.html.twig' %}

{% import "email/_macros.twig" as email %}

{% block subject %}Mon Indemnisation Justice: vous avez un nouveau dossier à transmettre à FIP3{% endblock subject %}

{% block entete %}
    <b>Mon Indemnisation Justice: vous avez un nouveau dossier à transmettre à FIP3</b>
{% endblock entete %}


{% block contenu %}
    Bonjour {{ agent.prenom }},
    <br/>
    <br/>
    <p>
        {{ dossier.etatDossier.agent.nomComplet }} vient de signer l'arrêté de paiement du
        dossier <b>{{ dossier.reference }}</b>, il peut désormais être transmis au bureau du budget.
    </p>
    <p>
        Vous pouvez consulter le dossier et le transmettre en cliquant sur le bouton ci-dessous :
    </p>
    <br/>
    <p>
        {{ email.bouton("Dossier " ~ dossier.reference, url('agent_fip6_react', {'extra': "dossier/" ~ dossier.id})) }}
        <br/>
    </p>
    <br/>
    Cordialement,<br/>
{% endblock contenu %}
