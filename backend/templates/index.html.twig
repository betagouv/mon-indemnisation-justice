{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('remixicon/fonts/remixicon.css') }}" rel="stylesheet"/>
    <style>
        .pr-content_body .pr-requests > ul, .pr-content_body .pr-requests > ul > li {
            margin: 0;
            padding: 0;
        }

        .pr-content_body .pr-requests ul li {
            list-style: none;
        }

        .pr-content_body .pr-requests ul li .fr-tile {
            box-shadow: rgba(0, 0, 0, 0.1) 0 4px 12px;
        }

        .fr-jumbotron {
            width: 100%;
            top: 0;
            left: 0;
            background-size: cover !important;
            background-position: 50% 50% !important;
            z-index: 0;
        }

        .fr-jumbotron--olympe-de-gouges {
            background-image: url('{{ asset("images/picture/olympe-de-gouges.png") }}');
        }

        .fr-text--bold {
            font-weight: bold;
        }

        .fr-text--white {
            color: var(--background-default-grey);
        }

        /** Section "Comment réagir ?" */

        @media (min-width: 992px) {
            .pr-comment-reagir {
                padding-right: 17%;
                background-image: url('{{ asset("images/undraw_searching.svg") }}');
                background-position: right center !important;
                background-repeat: no-repeat;
                background-size: 14%;
            }
        }

        h5 {
            margin: 1.5rem 0;
        }


        /** Section "Comment faire ma demande d'indemnisation ?" */

        .pr-section-comment-faire {
            padding: 1.5rem 0;
            /*background-color: #E6EEFE;*/
            background-color: var(--background-contrast-blue-cumulus);
        }


        @media (max-width: 991px) {
            .pr-section-comment-faire div.fr-container {
                display: flex;
                flex-direction: column;
            }

            .pr-section-comment-faire div.fr-container > *:not:first-child {
                margin-top: 1.5rem;
            }

            .pr-section-comment-faire div.fr-container > *:not:last-child {
                margin-bottom: 1.5rem;
            }

            .pr-section-comment-faire--etape {
                display: flex;
                flex-direction: column;
            }

            .pr-section-comment-faire--etape > *:not:first-child {
                margin-top: .75rem;
            }

            .pr-section-comment-faire--etape > *:not:last-child {
                margin-bottom: .75rem;
            }
        }

        @media (min-width: 992px) {
            .pr-section-comment-faire div.fr-container {
                display: flex;
                flex-direction: row;

            }

            .pr-section-comment-faire--etape {
                display: flex;
                flex-direction: row;
            }
        }


        .pr-section-comment-faire--titre {
            display: flex;
            flex-direction: column;
        }

        .pr-section-comment-faire--titre img {
            background: url('{{ asset("images/icon/icon-circle.svg") }}') center center no-repeat;
            width: 70%;
            margin: auto;
            padding: 3rem;
        }

        .pr-section-comment-faire--etape-icone {
            width: 4rem;
            margin-right: 1.5rem;
        }

        .pr-section-comment-faire--etape-icone span {
            width: 4rem;
            height: 4rem;
            border-radius: 50%;
            /*background-color: #000091;*/
            background-color: var(--text-active-blue-france);
            font-size: 1.6rem;
            font-weight: normal;
            /*color: #fff;*/
            color: var(--background-overlap-grey);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .pr-section-comment-faire--etape-description {
            display: flex;
            flex-direction: column;
        }

        .pr-section-comment-faire--etape-description h6 {
            /*color: #000091;*/
            color: var(--text-active-blue-france);
            margin: 0 0 1.5rem 0;
        }

        /** Section "Comment se passe ma demande d'indemnisation ?" */

        .pr-etapes-indemnisation-etape {
            position: relative;
            padding: 2rem 1rem;
        }

        .pr-etapes-indemnisation-etape:nth-child(1) {
            background-color: var(--background-overlap-grey);
        }

        .pr-etapes-indemnisation-etape:nth-child(2):before {
            /*background-color: #fff;*/
            background-color: var(--background-overlap-grey);
        }

        .pr-etapes-indemnisation-etape:nth-child(2) {
            /*background-color: #E6EEFE;*/
            background-color: var(--background-contrast-blue-cumulus);
        }

        .pr-etapes-indemnisation-etape:nth-child(3):before {
            background-color: var(--background-contrast-blue-cumulus);

        }

        .pr-etapes-indemnisation-etape:nth-child(3) {
            /*background-color: #BCD3FC;*/
            background-color: var(--background-contrast-blue-cumulus-hover);
        }

        {# Mobiles #}
        @media (max-width: 991px) {
            .pr-etapes-indemnisation-etape {
                padding: 1rem !important;
            }

            .pr-etapes-indemnisation-etape:not(:first-child) {
                padding-top: 3rem !important;
            }

            .pr-etapes-indemnisation-etape:not(:first-child):before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 2rem;
                mask: url('{{ asset("images/icon/icon-triangle-bottom.svg") }}') no-repeat;
                mask-size: 100% 2rem;
            }
        }

        {# Tablets and desktops #}
        @media (min-width: 992px) {
            .pr-etapes-indemnisation-etape:not(:first-child) {
                padding-left: 4rem;
            }

            .pr-etapes-indemnisation-etape:not(:first-child):before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 2.5rem;
                height: 100%;
                mask: url('{{ asset("images/icon/icon-triangle-right.svg") }}') no-repeat;
                mask-size: 2.5rem 80%;
            }
        }

        .pr-etapes-indemnisation--etape-icone {
            width: 4rem;
            height: 4rem;
            border-radius: 50%;
            /*background-color: #000091;*/
            background-color: var(--text-active-blue-france);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .pr-etapes-indemnisation--etape-icone span, .pr-etapes-indemnisation--etape-icone i {
            font-weight: bold;
            /*color: #fff;*/
            color: var(--background-overlap-grey);
        }

        .pr-etapes-indemnisation--etape-icone span:before, i:before {
            font-size: 1.8rem;
            font-weight: normal;
        }

        .pr-etapes-indemnisation-etape h6 {
            /*color: #000091;*/
            color: var(--text-active-blue-france);
            margin: 1.5rem 0;
        }

        /** Section "Je souhaite déposer ma demande d'indemnisation" */

        .pr-section-deposer {
            padding: 3rem 0;
            /*background-color: #eee;*/
            background-color: var(--background-contrast-grey);
        }

    </style>

{% endblock stylesheets %}

{% block containerClasses %}{% endblock containerClasses %}

{% block main %}
    <section class="fr-jumbotron fr-jumbotron--olympe-de-gouges fr-py-3w">
        <div class="fr-container">
            <div class="fr-col-md-9">
                <div class="fr-grid-col">
                    <h1 class="fr-h1 fr-mt-3w fr-text--white">Votre porte a été endommagée par erreur par les forces de
                        l’ordre
                        au cours d'une opération de police judiciaire ?</h1>
                    <p class="fr-text--white">
                        Mon Indemnisation Justice est un service en ligne qui vous permet de faire une demande
                        d’indemnisation
                        pour un bris de porte ou tout autre dégât matériel causé dans le cadre d’une opération de police
                        judiciaire.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="fr-my-6w">
        <div class="fr-container">
            <h3>Comment utiliser notre service en ligne ?</h3>

            <h5>Vous avez reçu un email d’invitation à la suite de la déclaration des forces de l'ordre ?</h5>

            <p>
                Les forces de l’ordre ont déjà déclaré le bris de porte au ministère de la Justice et initié votre
                dossier.
            </p>

            <p>
                Accédez à notre service en ligne via le mail d’invitation et complétez votre dossier en joignant les
                pièces demandées.
            </p>

            <h5>Vous avez reçu un avis d'intervention à la suite de l'opération des forces de l'ordre?</h5>

            <p>
                Nous vous invitons à vous rendre au commissariat ou à la brigade de gendarmerie dont les coordonnées
                figurent sur l'avis d'intervention afin qu'un agent déclare le bris de porte et initie votre dossier sur
                Mon Indemnisation Justice.
            </p>

            <p>
                Vous recevrez ensuite un email avec un lien pour vous connecter à notre service en ligne et compléter
                votre dossier en joignant les pièces demandées.
            </p>


            <h5>Vous avez reçu une attestation papier des forces de l'ordre ?</h5>

            <p>Assurez vous que l’agent a complété l’espace qui lui est réservé : date et adresse de l’opération de
                police judiciaire, nom et coordonnées du service enquêteur, numéro de parquet ou d’instruction.</p>

            <div class="fr-alert fr-alert--warning fr-alert--sm">

                <p>
                    Avant de déposer votre dossier en ligne, vous devez tester votre éligibilité à
                    l'indemnisation.
                </p>
            </div>

            <ul class="fr-btns-group fr-btns-group--inline fr-my-2w ">
                <li>
                    <a class="fr-btn" role="link" href="{{ url('bris_porte_tester_eligibilite') }}">
                        Tester mon éligibilité à l'indemnisation
                    </a>
                </li>
            </ul>

            <h5>Vous n'avez pas reçu d'attestation ni d'avis d'intervention de la part des forces de l'ordre ?</h5>

            <p>Rendez vous à votre commissariat ou à votre brigade de gendarmerie afin qu'un agent déclare le bris de
                porte et initie votre dossier sur Mon Indemnisation Justice.</p>
            <p>Vous recevrez ensuite un email avec un lien pour vous connecter à notre service en ligne et compléter
                votre dossier en joignant les pièces demandées.</p>


            <ul class="fr-btns-group fr-btns-group--inline fr-my-2w ">
                <li>
                    <a class="fr-btn" role="link" target="_blank"
                       href="https://www.masecurite.interieur.gouv.fr/fr/trouver-un-commissariat-une-gendarmerie">
                        Localiser le commissariat / la gendarmerie
                    </a>
                </li>
            </ul>

            <div class="fr-callout fr-icon-info-line">
                <h3 class="fr-callout__title">Conditions d’indemnisation</h3>
                <p>Deux conditions cumulatives d’indemnisation :</p>
                <ul class="fr-my-2w">
                    <li>
                        Vous ne devez pas être concerné(e) par l'opération de police judiciaire <b>ET</b>
                    </li>
                    <li>
                        L'opération de police judiciaire doit avoir été réalisée par erreur à votre domicile.
                    </li>
                </ul>
            </div>

            <div class="fr-alert fr-alert--warning fr-alert--sm">
                <p>
                    Seuls les frais de remise en état à l’identique de la porte endommagée seront remboursés.
                </p>
            </div>


        </div>
    </section>

    <section class="fr-my-6w pr-section-comment-reagir">
        <div class="fr-container">
            <h3>Les bons réflexes</h3>

            <div class="pr-comment-reagir--reflexes">

                <ol>

                    <li>Rendez vous à votre commissariat ou gendarmerie</li>
                    <li>Connectez-vous via le lien reçu par mail de *Mon Indemnisation Justice*</li>
                    <li>Identifiez-vous via FranceConnect ou créez votre compte</li>
                    <li>Téléversez les documents demandés :
                        <ul>
                            <li>Une photo de la porte endommagée</li>
                            <li>Une attestation de non prise en charge du sinistre par votre assurance</li>
                            <li>Une attestation de non prise en charge du sinistre par votre bailleur (si vous êtes
                                locataire)
                            </li>
                            <li>Une copie recto-verso de votre pièce d’identité ou un extrait Kbis de moins de 3 mois
                                (si vous êtes une personne morale)
                            </li>
                            <li>La facture acquittée attestant de la réalité des travaux de remise en état à
                                l'identique
                            </li>
                            <li>Votre titre de propriété ou votre contrat de bail</li>
                        </ul>
                    </li>
                </ol>

                <p>
                    Un accusé de réception vous sera envoyé après le dépôt de votre dossier. Vous recevrez des
                    notifications par email à chaque étape du traitement de votre dossier. Restez attentif afin de
                    faciliter et accélérer votre indemnisation.

                </p>

                <div class="fr-alert fr-alert--warning fr-alert--sm">

                    <p>
                        <b>Si un serrurier est intervenu à la demande des forces de l’ordre pour sécuriser votre
                            logement, vous n’avez pas à régler sa facture.</b>
                    </p>
                </div>
            </div>


        </div>
    </section>

    {#
    <section class="fr-my-6w pr-section-comment-faire">
        <div class="fr-container">
            <div class="fr-col-lg-6 fr-col-12 pr-section-comment-faire--titre">
                <h3>Comment faire votre demande d'indemnisation ?</h3>

                <img src="{{ asset('images/undraw_image_folder.svg') }}" alt="Icône recherche dossier"/>
            </div>

            <div class="fr-col-lg-6 fr-col-12 pr-section-comment-faire--etapes">
                <div class="pr-section-comment-faire--etape">
                    <div class="pr-section-comment-faire--etape-icone">
                        <span>1</span>
                    </div>

                    <div class="pr-section-comment-faire--etape-description">
                        <h6>Testez votre éligibilité à l’indemnisation</h6>
                        <p>
                            Afin de vérifier votre éligibilité à l’indemnisation, vous devez répondre à quelques
                            questions.
                        </p>
                    </div>
                </div>

                <div class="pr-section-comment-faire--etape">
                    <div class="pr-section-comment-faire--etape-icone">
                        <span>2</span>
                    </div>

                    <div class="pr-section-comment-faire--etape-description">
                        <h6>Créez votre compte via FranceConnect</h6>
                        <p>
                            Votre compte vous permet de constituer votre dossier, de recevoir des messages de nos
                            services
                            et de suivre l’état d’avancement du traitement de votre demande.
                        </p>
                    </div>
                </div>

                <div class="pr-section-comment-faire--etape">
                    <div class="pr-section-comment-faire--etape-icone">
                        <span>3</span>
                    </div>

                    <div class="pr-section-comment-faire--etape-description">
                        <h6>Constituez votre dossier</h6>
                        <p>
                            Vous devez compléter le formulaire de demande d’indemnisation en vous aidant des
                            informations figurant sur l’attestation remise par l’agent des forces de l’ordre.
                        </p>

                        <p class="fr-mb-0">Vous devez également transmettre les documents demandés :</p>

                        <ul>
                            <li>Attestation d’information complétée par les forces de l’ordre</li>
                            <li>Au moins une photo de la porte endommagée</li>
                            <li>Attestation de non prise en charge du sinistre par votre assurance habitation</li>
                            <li>Attestation de non prise en charge du sinistre par le bailleur (si locataire)</li>
                            <li>Copie recto-verso de votre pièce d’identité ou un extrait Kbis de moins de 3 mois
                                (si
                                vous êtes une personne morale)
                            </li>
                            <li>La facture acquittée attestant de la réalité des travaux de remise en état à
                                l'identique
                            </li>
                            <li>Votre titre de propriété ou votre contrat de bail</li>

                        </ul>
                    </div>
                </div>

                <div class="pr-section-comment-faire--etape">
                    <div class="pr-section-comment-faire--etape-icone">
                        <span>4</span>
                    </div>

                    <div class="pr-section-comment-faire--etape-description">
                        <h6>Envoyez votre demande d’indemnisation</h6>
                        <p>
                            Vérifiez l’exactitude des informations fournies avant de nous transmettre votre demande
                            d’indemnisation.
                        </p>
                    </div>
                </div>

            </div>

        </div>
    </section>
    #}

    <section class="fr-my-6w">
        <div class="fr-container">
            <h3>Comment se passe le traitement de votre demande d'indemnisation ?</h3>

            <p>Vous avez constitué et déposé votre dossier ? Quelles sont les prochaines étapes ?</p>

            <div class="pr-etapes-indemnisation fr-grid-row fr-mb-3w">
                <div class="fr-col-12 fr-col-lg-4 pr-etapes-indemnisation-etape">
                    {# Icone #}
                    <div class="pr-etapes-indemnisation--etape-icone">
                        <i class="ri-search-2-line" aria-hidden="true"></i>
                    </div>

                    <h6>Instruction de votre dossier</h6>

                    <p>
                        Nos services peuvent vous demander des informations ou pièces complémentaires. Les services
                        enquêteurs peuvent également être interrogés.

                    </p>
                </div>

                <div class="fr-col-12 fr-col-lg-4 pr-etapes-indemnisation-etape">

                    <div class="pr-etapes-indemnisation--etape-icone">
                        <i class="ri-shake-hands-line" aria-hidden="true"></i>
                    </div>

                    <h6>Proposition d’indemnisation</h6>

                    <p>
                        Une proposition d’indemnisation vous est adressée si vous remplissez les conditions requises.
                    </p>
                </div>

                <div class="fr-col-12 fr-col-lg-4  pr-etapes-indemnisation-etape">

                    <div class="pr-etapes-indemnisation--etape-icone">
                        <i class="ri-bank-line" aria-hidden="true"></i>
                    </div>

                    <h6>Indemnisation</h6>

                    <p>
                        Après acceptation de la proposition, l’indemnisation est versée par virement bancaire.
                    </p>
                </div>

            </div>

        </div>

    </section>

{% endblock %}
