                        this.statuer(this.reponses);
                    } else {
                        Object.keys(this.reponses).forEach(function (c) { return this.reponses[c] = null; });
                        this.decisions.length = 0;
                    }
                },
            };
        };
    </script>
     #}
{% endblock javascripts %}
