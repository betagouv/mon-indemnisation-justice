                statuer: function (reponses) {
                    this.decisions.length = 0;
                    // Statuer sur une décision ici :
                    if (reponses.estVise) {
                        this.decisions.push({
                            name: "error_est_vise",
                            eligible: false
                        });
                    } else if (reponses.estRecherche) {
                        this.decisions.push({
                            name: "error_est_recherche",
                            eligible: false
