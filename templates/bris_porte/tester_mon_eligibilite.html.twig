                            if (reponses.aContacteAssurance != null && reponses.aContacteBailleur != null) {
                                if (reponses.aContacteAssurance === false) {
                                    this.decisions.push({
                                        name: "warning_locataire_assurance"
                                    });
                                }
                                if (reponses.aContacteBailleur === false) {
