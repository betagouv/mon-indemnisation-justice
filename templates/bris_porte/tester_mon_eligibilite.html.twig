{% extends 'base.html.twig' %}

{% block title %}Bris de porte : tester mon éligibilité{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# <script src="{{ asset('build/alpinejs/cdn.js') }}" defer></script> #}
    <style>
        form[name="eligibilite-test-form"] {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .pr-section-formulaire {
            /* fr-my-3w */
            /*margin: 1.5rem 0;*/
            /* fr-px-3w && fr-py-4w */
            padding: 1.5rem 2rem;
            box-shadow:0 0 8px 2px var(--shadow-color);
        }

        .pr-section-formulaire h4 {
            font-weight: 400 !important;
        }

        /* AlpineJS */
        [x-cloak] {
            display: none !important;
        }
    </style>
{% endblock stylesheets %}

{% block header %}
    {% include('bris_porte/_header.html.twig') %}
{% endblock header %}

{% block main %}
    <div class="fr-container fr-my-3w">
        {#  Indicateur d'étapes #}
        <div class="fr-stepper">
            <h2 class="fr-stepper__title">
                Tester mon éligibilité
                <span class="fr-stepper__state">Étape 1 sur 3</span>
            </h2>
            <div class="fr-stepper__steps" data-fr-current-step="1" data-fr-steps="3"></div>
            <p class="fr-stepper__details">
                <span class="fr-text--bold">Étape suivante :</span> Création de mon compte
            </p>
        </div>

        <div class="fr-col-12" id="react-app" data-form-url={{ url(app.current_route) }}" data-csrf-token="{{ form._token.vars.value }}">
            {#
                Désactivé le temps de la transition
                {% include 'bris_porte/_form_test_eligibilite.html.twig' %}
            #}

        </div>
    </div>
{% endblock main %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('bris-porte-tester-mon-eligibilite') }}
    {#
    <script type="text/javascript">
        function eligibiliteTestForm() {

            return {
